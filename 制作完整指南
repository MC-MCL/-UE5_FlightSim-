### 文件2: `AirplanePawn.cpp` (飞行器Pawn实现文件)
```cpp
// AirplanePawn.cpp
#include "AirplanePawn.h"
#include "Components/StaticMeshComponent.h"
#include "Camera/CameraComponent.h"
#include "GameFramework/SpringArmComponent.h"
#include "Components/InputComponent.h"
#include "Engine/Engine.h"

AAirplanePawn::AAirplanePawn()
{
    PrimaryActorTick.bCanEverTick = true;

    // 创建网格体组件
    AirplaneMesh = CreateDefaultSubobject<UStaticMeshComponent>(TEXT("AirplaneMesh"));
    RootComponent = AirplaneMesh;
    AirplaneMesh->SetSimulatePhysics(true);
    AirplaneMesh->SetMassOverrideInKg(NAME_None, 1000.0f);

    // 创建弹簧臂
    SpringArm = CreateDefaultSubobject<USpringArmComponent>(TEXT("SpringArm"));
    SpringArm->SetupAttachment(RootComponent);
    SpringArm->TargetArmLength = 500.0f;
    SpringArm->bUsePawnControlRotation = false;

    // 创建摄像机
    Camera = CreateDefaultSubobject<UCameraComponent>(TEXT("Camera"));
    Camera->SetupAttachment(SpringArm, USpringArmComponent::SocketName);

    // 初始化状态
    CurrentThrottle = 0.0f;
    CurrentPitch = 0.0f;
    CurrentYaw = 0.0f;
    CurrentRoll = 0.0f;
}

void AAirplanePawn::BeginPlay()
{
    Super::BeginPlay();
}

void AAirplanePawn::Tick(float DeltaTime)
{
    Super::Tick(DeltaTime);

    // 应用推力
    FVector Forward = GetActorForwardVector();
    FVector ThrustForce = Forward * CurrentThrottle * ThrottleSpeed;
    AirplaneMesh->AddForce(ThrustForce);

    // 应用升力（基于速度）
    FVector Velocity = AirplaneMesh->GetPhysicsLinearVelocity();
    float Speed = Velocity.Size();
    if (Speed > 100.0f)
    {
        float Lift = Speed * LiftCoefficient;
        FVector LiftForce = FVector(0, 0, Lift);
        AirplaneMesh->AddForce(LiftForce);
    }

    // 应用旋转
    FRotator RotationDelta = FRotator(CurrentPitch * PitchSpeed, CurrentYaw * YawSpeed, CurrentRoll * RollSpeed) * DeltaTime;
    AddActorLocalRotation(FRotator(RotationDelta.Pitch, RotationDelta.Yaw, RotationDelta.Roll));
}

void AAirplanePawn::SetupPlayerInputComponent(UInputComponent* PlayerInputComponent)
{
    Super::SetupPlayerInputComponent(PlayerInputComponent);

    // 绑定轴映射
    PlayerInputComponent->BindAxis("MoveForward", this, &AAirplanePawn::MoveForward);
    PlayerInputComponent->BindAxis("MoveRight", this, &AAirplanePawn::MoveRight);
    PlayerInputComponent->BindAxis("Pitch", this, &AAirplanePawn::Pitch);
    PlayerInputComponent->BindAxis("Yaw", this, &AAirplanePawn::Yaw);
    PlayerInputComponent->BindAxis("Roll", this, &AAirplanePawn::Roll);
    PlayerInputComponent->BindAxis("Ascend", this, &AAirplanePawn::Ascend);

    // 绑定动作映射
    PlayerInputComponent->BindAction("ThrottleUp", IE_Pressed, this, &AAirplanePawn::ThrottleUp);
    PlayerInputComponent->BindAction("ThrottleDown", IE_Pressed, this, &AAirplanePawn::ThrottleDown);
}

void AAirplanePawn::MoveForward(float Value)
{
    // 已由Tick中的推力处理
}

void AAirplanePawn::MoveRight(float Value)
{
    // 横移（可选）
    FVector Right = GetActorRightVector();
    AirplaneMesh->AddForce(Right * Value * 50000.0f);
}

void AAirplanePawn::Pitch(float Value)
{
    CurrentPitch = Value;
}

void AAirplanePawn::Yaw(float Value)
{
    CurrentYaw = Value;
}

void AAirplanePawn::Roll(float Value)
{
    CurrentRoll = Value;
}

void AAirplanePawn::ThrottleUp()
{
    CurrentThrottle = FMath::Clamp(CurrentThrottle + 0.1f, 0.0f, 1.0f);
}

void AAirplanePawn::ThrottleDown()
{
    CurrentThrottle = FMath::Clamp(CurrentThrottle - 0.1f, 0.0f, 1.0f);
}

void AAirplanePawn::Ascend(float Value)
{
    FVector Up = GetActorUpVector();
    AirplaneMesh->AddForce(Up * Value * 50000.0f);
}
```

